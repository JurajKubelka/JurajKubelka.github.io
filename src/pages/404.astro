---
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../lib/site";

const basePath = import.meta.env.BASE_URL;
---

<BaseLayout
  lang="en"
  locale="en-US"
  title="Page not found | Juraj Kubelka"
  description="This page does not exist."
  path="/404/"
>
  <main class="not-found-shell">
    <div class="card not-found-card">
      <p class="eyebrow">404</p>
      <h1>Page not found</h1>
      <p>The page you are looking for is not here. Try one of the language homepages instead.</p>
      <div class="not-found-links">
        <a class="button-link" href={withBase(basePath, "/")}>English</a>
        <a class="button-link secondary" href={withBase(basePath, "/cs/")}>Česky</a>
        <a class="button-link secondary" href={withBase(basePath, "/es/")}>Español</a>
      </div>
    </div>
  </main>
</BaseLayout>
